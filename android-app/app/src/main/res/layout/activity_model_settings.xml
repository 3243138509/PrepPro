<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_app_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="模型设置"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/ink_900" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="添加多个 MODEL_API_URL / MODEL_API_KEY / MODEL_NAME"
            android:textColor="@color/ink_600"
            android:textSize="13sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/surface_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="MODEL_API_URL"
                    app:boxBackgroundMode="filled"
                    app:boxStrokeColor="@color/accent_teal">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputModelApiUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="MODEL_API_KEY"
                    app:boxBackgroundMode="filled"
                    app:boxStrokeColor="@color/accent_teal">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputModelApiKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="MODEL_NAME"
                    app:boxBackgroundMode="filled"
                    app:boxStrokeColor="@color/accent_teal">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputModelName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonDetectModels"
                        style="@style/Widget.PrepPro.Button.Secondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="检测模型" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonAddModelSetting"
                        style="@style/Widget.PrepPro.Button.Primary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="添加并启用" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="20dp"
            app:strokeColor="@color/surface_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已保存模型"
                    android:textColor="@color/ink_900"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerModelProfiles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_field"
                    android:padding="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonUseSelectedProfile"
                    style="@style/Widget.PrepPro.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="使用当前选中模型" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonDeleteSelectedProfile"
                    style="@style/Widget.PrepPro.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="删除当前选中模型" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonBatchDeleteProfiles"
                    style="@style/Widget.PrepPro.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="批量删除模型" />

                <TextView
                    android:id="@+id/textModelStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="状态: 待操作"
                    android:textColor="@color/ink_700"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
