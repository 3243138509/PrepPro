<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F7FCFC" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="#B9D4D4" />
        </shape>
    </item>

    <item
        android:width="18dp"
        android:height="18dp"
        android:gravity="end|center_vertical"
        android:right="12dp"
        android:drawable="@drawable/ic_spinner_chevron" />
</layer-list>